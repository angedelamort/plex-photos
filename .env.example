# Copie ce fichier en .env et remplis les valeurs. NE JAMAIS committer .env.

# URL du serveur Plex, joignable depuis le conteneur
PLEX_SERVER_URL=http://192.168.1.10:32400

# Machine ID du serveur Plex (vérifie que l'user a accès à CE serveur)
# Récupère-le avec : curl -s http://<plex-host>:32400/identity
PLEX_MACHINE_ID=abc123def456

# URL publique de plex-photos, utilisée pour le retour OAuth Plex
# ex: https://photos.mondomaine.com
PUBLIC_BASE_URL=https://photos.example.com

# Clé de signature des cookies — OPTIONNELLE.
# Si vide, une clé aléatoire est générée et persistée dans <DATA_PATH>/session.key
# au premier démarrage. Ne la définis que pour figer une valeur précise.
# SESSION_SECRET=
